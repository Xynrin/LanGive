<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Go JNI handles raw TCP socket communication for local transfers, which is unaffected by Java-level cleartext rules.
         Here we disable global cleartext traffic for Java libraries but allow localhost and local naming for compliance. -->
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">192.168.1.1</domain>
        <domain includeSubdomains="true">192.168.0.1</domain>
    </domain-config>
</network-security-config>
